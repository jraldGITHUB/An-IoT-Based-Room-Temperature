<?php

$conn = new mysqli("localhost","root","","iot_monitor");

$sql = "
SELECT devices.room_name, sensor_data.temperature, sensor_data.ac_status, sensor_data.fan_status
FROM sensor_data
JOIN devices ON devices.id = sensor_data.device_id
ORDER BY sensor_data.id DESC
LIMIT 1
";

$result = $conn->query($sql);

echo json_encode($result->fetch_assoc());

?>